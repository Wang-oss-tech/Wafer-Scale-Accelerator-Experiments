#!/usr/bin/env bash
# Runs all GEMV experiment configurations and appends output to results.txt

set -e

OUT="results.txt"
> "$OUT"
mkdir -p log

run_config() {
    local P=$1 M=$2 N=$3 group_num=$4
    local Mt=$((M / P))
    local Nt=$((N / P))
    local pe_num_group=$((P / group_num))
    local root_1st_phase=$((pe_num_group / 2))
    local root_2nd_phase=$(((group_num / 2) * pe_num_group + root_1st_phase))

    echo "========================================" | tee -a "$OUT"
    echo "Grid: ${P} x ${P} PEs" | tee -a "$OUT"
    echo "Tile sizes: Mt=${Mt}, Nt=${Nt}" | tee -a "$OUT"
    echo "Full matrix: x(1x${M}) * W(${M}x${N})" | tee -a "$OUT"
    echo "group_num=${group_num}, pe_num_group=${pe_num_group}" | tee -a "$OUT"
    echo "========================================" | tee -a "$OUT"

    python3 compile.py "$P" "$Mt" "$Nt" "$group_num" "$pe_num_group" "$root_1st_phase" "$root_2nd_phase" false 2>&1 | tee -a "$OUT"
    python3 appliance_launch.py --P "$P" --M "$M" --N "$N" --group_num "$group_num" --warmup 0 --repeats 1 2>&1 | tee -a "$OUT"

    echo "" | tee -a "$OUT"
}

# GEMV ~4K  (M=N=4320 for P=120,240,360,480; 4800 for P=600)
run_config 120 4320 4320  8
run_config 240 4320 4320 16
run_config 360 4320 4320 24
run_config 480 4320 4320 32
run_config 600 4800 4800 40

# GEMV ~8K  (M=N=8640 for P=120,240,360,480; 7200 for P=600)
run_config 120 8640 8640  8
run_config 240 8640 8640 16
run_config 360 8640 8640 24
run_config 480 8640 8640 32
run_config 600 7200 7200 40

# GEMV 16K  (M=N=14400, divisible by all P)
run_config 120 14400 14400  8
run_config 240 14400 14400 16
run_config 360 14400 14400 24
run_config 480 14400 14400 32
run_config 600 14400 14400 40

echo "All experiments complete. Results saved to $OUT"
